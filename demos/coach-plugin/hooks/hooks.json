{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "powershell",
            "command": "$d=[Console]::In.ReadToEnd()|ConvertFrom-Json; $ts=Get-Date -Format 'yyyy-MM-dd HH:mm:ss'; $log=\"${CLAUDE_PLUGIN_DATA}\\bash-log.txt\"; Add-Content -LiteralPath $log -Value \"$ts | Bash tool executed | $($d.tool_input.command)\"",
            "statusMessage": "Logging bash command"
          }
        ]
      }
    ]
  }
}
